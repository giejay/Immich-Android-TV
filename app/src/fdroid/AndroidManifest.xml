<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Remove Google Play Billing permission – not used in the F-Droid flavor -->
    <uses-permission android:name="com.android.vending.BILLING" tools:node="remove" />

    <!-- Remove GMS AD_ID entry – not needed without Google Play Services -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />

    <application>
        <!-- Remove Cast Connect receiver options meta-data – not used in the F-Droid flavor -->
        <meta-data
            android:name="com.google.android.gms.cast.tv.RECEIVER_OPTIONS_PROVIDER_CLASS_NAME"
            tools:node="remove" />
    </application>

</manifest>
